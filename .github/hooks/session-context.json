{
    "hooks": {
        "SessionStart": [
            {
                "type": "command",
                "command": "pwsh -NoProfile -File ./.github/hooks/scripts/session-context.ps1",
                "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\.github\\hooks\\scripts\\session-context.ps1",
                "cwd": ".",
                "timeout": 30
            }
        ]
    }
}